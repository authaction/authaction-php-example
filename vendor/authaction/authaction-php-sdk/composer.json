{
    "name": "authaction/authaction-php-sdk",
    "description": "AuthAction JWT verification SDK for PHP — Laravel, PSR-15, plain PHP",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "firebase/php-jwt": "^6.0 || ^7.0"
    },
    "config": {
        "audit": {
            "ignore": {
                "PKSA-y2cr-5h3j-g3ys": "Advisory assessed: library used only for RS256 signature verification with JWKS; attack vectors do not apply to this usage pattern."
            }
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "psr/http-server-middleware": "^1.0",
        "psr/http-server-handler": "^1.0",
        "psr/http-message": "^1.0|^2.0",
        "psr/http-factory": "^1.0"
    },
    "suggest": {
        "illuminate/http": "Required for Laravel middleware support",
        "psr/http-server-middleware": "Required for PSR-15 middleware support"
    },
    "autoload": {
        "psr-4": { "AuthAction\\": "src/" }
    },
    "autoload-dev": {
        "psr-4": { "AuthAction\\Tests\\": "tests/" }
    },
    "minimum-stability": "stable"
}
